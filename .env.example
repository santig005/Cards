# ─── Supabase ────────────────────────────────────────────────────────────────
# Obtener en: https://supabase.com/dashboard → proyecto → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>

# Solo server-side. Nunca exponer al cliente ni commitear el valor real.
SUPABASE_SERVICE_ROLE_KEY=<service-role-secret-key>

# ─── Base de datos ────────────────────────────────────────────────────────────
# Obtener en: Supabase Dashboard → Settings → Database → Connection string

# Transaction pooler (puerto 6543) — para la app en producción/Vercel
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# Conexión directa (puerto 5432) — solo para migraciones con drizzle-kit
DATABASE_URL_DIRECT=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# ─── App ─────────────────────────────────────────────────────────────────────
# URL pública de la app (sin trailing slash). En local: http://localhost:3000
# En producción: https://tu-dominio.vercel.app

NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Web Push (VAPID) ─────────────────────────────────────────────────────────
# Generar par de claves con: pnpm dlx web-push generate-vapid-keys
# La pública va también como NEXT_PUBLIC_ (la usa el navegador para suscribirse).
VAPID_PUBLIC_KEY=<vapid-public-key>
VAPID_PRIVATE_KEY=<vapid-private-key>
VAPID_SUBJECT=mailto:soporte@sellio.app
NEXT_PUBLIC_VAPID_PUBLIC_KEY=<vapid-public-key>
