# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env.local
.env.*.local

# drizzle — los snapshots/journal generados se ignoran, pero las migraciones SQL
# (incluidas las de RLS escritas a mano) SÍ se versionan.
/supabase/migrations/meta

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/prompts

# claude code worktrees / local agent dirs
.claude/worktrees/
